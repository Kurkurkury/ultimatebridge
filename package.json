    "smoke:release-package-stable-freeze": "node scripts/smoke-release-package-stable-freeze.mjs",
    "smoke:local-diagnostics": "node scripts/smoke-local-diagnostics.mjs",
    "smoke:final-docs-freeze": "node scripts/smoke-final-docs-freeze.mjs",
