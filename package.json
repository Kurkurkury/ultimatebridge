{
  "name": "ultimatebridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Clean-room successor foundation for AutoBridge 5.",
  "scripts": {
    "test": "node --test tests/**/*.test.mjs",
    "check:schemas": "node scripts/check-schemas.mjs",
    "check:powershell": "pwsh -NoProfile -File scripts/check-powershell.ps1",
    "smoke:readonly": "node scripts/smoke-readonly-request.mjs",
    "smoke:safe-change": "node scripts/smoke-safe-change.mjs",
    "smoke:delivery": "node scripts/smoke-report-delivery.mjs",
    "smoke:extension-queue": "node scripts/smoke-extension-delivery-queue.mjs",
    "smoke:confirmed-plan": "node scripts/smoke-confirmed-plan.mjs",
    "smoke:project-roots": "node scripts/smoke-project-roots.mjs",
    "smoke:rollback": "node scripts/smoke-rollback.mjs",
    "smoke:preview-diff": "node scripts/smoke-preview-diff.mjs",
    "smoke:preview-apply": "node scripts/smoke-preview-handshake.mjs",
    "smoke:extension-preview-ui": "node scripts/smoke-extension-preview-ui.mjs",
    "smoke:browser-safe-change-builder": "node scripts/smoke-browser-safe-change-builder.mjs",
    "smoke:browser-apply-injection": "node scripts/smoke-browser-apply-block-injection.mjs",
    "smoke:manual-send-guard": "node scripts/smoke-manual-send-guard.mjs",
    "e2e:native": "node scripts/e2e-native-message.mjs",
    "ci": "npm run check:schemas && npm test"
  },
  "engines": {
    "node": ">=20"
  }
}
