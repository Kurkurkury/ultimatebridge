    "smoke:browser-session-summary": "node scripts/smoke-browser-session-summary.mjs",
    "smoke:browser-command-templates": "node scripts/smoke-browser-command-template-library.mjs",
    "smoke:browser-project-root-memory": "node scripts/smoke-browser-project-root-memory.mjs",
    "smoke:browser-project-root-labels": "node scripts/smoke-browser-project-root-labels.mjs",
    "smoke:browser-root-aware-command-templates": "node scripts/smoke-browser-root-aware-command-templates.mjs",
    "smoke:browser-root-aware-popup-wiring": "node scripts/smoke-browser-root-aware-popup-wiring.mjs",
