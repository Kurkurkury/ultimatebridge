    "smoke:native-host-install-rehearsal": "node scripts/smoke-native-host-install-rehearsal.mjs",
    "launcher:plan": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/Start-UltimateBridge.ps1",
