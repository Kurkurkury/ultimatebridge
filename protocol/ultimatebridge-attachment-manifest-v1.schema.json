{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ultimatebridge.local/schemas/ultimatebridge-attachment-manifest-v1.schema.json",
  "title": "UltimateBridge Attachment Manifest V1",
  "type": "object",
  "required": ["protocol", "jobId", "items"],
  "properties": {
    "protocol": { "const": "ULTIMATEBRIDGE_ATTACHMENT_MANIFEST_V1" },
    "jobId": { "type": "string" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "kind", "size", "sha256", "upload"],
        "properties": {
          "path": { "type": "string" },
          "kind": { "type": "string" },
          "size": { "type": "integer", "minimum": 0 },
          "sha256": { "type": "string" },
          "upload": { "type": "boolean" },
          "reason": { "type": "string" }
        }
      }
    }
  },
  "additionalProperties": false
}
