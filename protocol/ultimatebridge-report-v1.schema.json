{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ultimatebridge.local/schemas/ultimatebridge-report-v1.schema.json",
  "title": "UltimateBridge Runner Report V1",
  "type": "object",
  "required": ["protocol", "requestId", "jobId", "status", "timedOut"],
  "properties": {
    "protocol": { "const": "ULTIMATEBRIDGE_RUNNER_REPORT_V1" },
    "requestId": { "type": "string" },
    "jobId": { "type": "string" },
    "status": { "enum": ["OK", "WARN", "ERROR", "BLOCKED", "TIMEOUT"] },
    "exitCode": { "type": "integer" },
    "timedOut": { "type": "boolean" },
    "timeoutSeconds": { "type": "integer" },
    "runFolder": { "type": "string" },
    "summary": { "type": "string" },
    "attachments": { "type": "array" }
  },
  "additionalProperties": true
}
