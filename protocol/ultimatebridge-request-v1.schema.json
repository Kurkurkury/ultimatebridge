{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ultimatebridge.local/schemas/ultimatebridge-request-v1.schema.json",
  "title": "UltimateBridge Request V1",
  "type": "object",
  "required": ["protocol", "requestId", "mode"],
  "properties": {
    "protocol": { "const": "ULTIMATEBRIDGE_REQUEST_V1" },
    "requestId": { "type": "string", "minLength": 1 },
    "mode": { "enum": ["READ_ONLY", "SAFE_CHANGE", "PROJECT_CHANGE", "EXECUTION_LOCKED"] },
    "targetHost": { "type": "string" },
    "taskName": { "type": "string" },
    "createdBy": { "type": "string" },
    "body": { "type": "string" },
    "approvedProjectRoot": { "type": "string" },
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["op", "path"],
        "properties": {
          "op": { "enum": ["writeTextFile", "replaceText"] },
          "path": { "type": "string" },
          "content": { "type": "string" },
          "search": { "type": "string" },
          "replace": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
